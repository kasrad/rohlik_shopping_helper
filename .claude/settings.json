{
  "permissions": {
    "allow": [
      "Read(/**)",
      "Edit(/**)",
      "Write(/**)",
      "Bash"
    ],
    "ask": [
      "Read(/.env)",
      "Read(/.env.local)",
      "Read(/**/.env)",
      "Read(/**/.env.local)",
      "Edit(/.env)",
      "Edit(/.env.local)",
      "Edit(/**/.env)",
      "Edit(/**/.env.local)",
      "Write(/.env)",
      "Write(/.env.local)",
      "Write(/**/.env)",
      "Write(/**/.env.local)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "denyRead": ["./.env", "./.env.local"]
    }
  }
}
